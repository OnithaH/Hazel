// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String   @id @default(uuid())
  clerk_id              String   @unique // Shared Account ID
  email                 String   @unique
  name                  String?
  weekly_study_goal     Int      @default(15)
  is_premium            Boolean  @default(false)
  privacy_mode_enabled  Boolean  @default(false)
  spotify_refresh_token String?
  google_refresh_token  String?
  created_at            DateTime @default(now())

  // Relations
  robots                Robot[]  // One user, multiple robots
}

model Robot {
  id           String   @id @default(uuid())
  name         String   // "Onitha's Robot", etc.
  secret_key   String   @unique @default(uuid())
  user_id      String
  user         User     @relation(fields: [user_id], references: [id])
  created_at   DateTime @default(now())

  // Data linked to Specific Robot
  studySessions       StudySession[]
  gameSessions        GameSession[]
  environmentLogs     EnvironmentLog[]
  aromaConfigurations AromaConfiguration[]
  reminders           Reminder[]
  musicGenreMappings  MusicGenreMapping[]
  modeUsageLogs       ModeUsageLog[]
}

model StudySession {
  id                      String   @id @default(uuid())
  robot_id                String?
  robot                   Robot?   @relation(fields: [robot_id], references: [id])
  start_time              DateTime
  end_time                DateTime?
  scheduled_duration      Int
  actual_focus_time       Int?
  focus_goal              String?
  phone_detection_enabled Boolean  @default(false)
  focus_shield_enabled    Boolean  @default(false)
  break_activity          String?
  break_used              Boolean  @default(false)
  created_at              DateTime @default(now())

  distractions            DistractionLog[]
}

model DistractionLog {
  id          String   @id @default(uuid())
  session_id  String
  session     StudySession @relation(fields: [session_id], references: [id])
  type        String   // 'PHONE', 'DROWSINESS'
  timestamp   DateTime @default(now())
}

model EnvironmentLog {
  id          String   @id @default(uuid())
  robot_id    String?
  robot       Robot?   @relation(fields: [robot_id], references: [id])
  temperature Float
  humidity    Float
  recorded_at DateTime @default(now())
}

model AromaConfiguration {
  id             String   @id @default(uuid())
  robot_id       String?
  robot          Robot?    @relation(fields: [robot_id], references: [id])
  chamber_number Int
  scent_name     String
  intensity      Int      @default(75)
  color_hex      String?
  isActive       Boolean  @default(true)
  updated_at     DateTime @updatedAt
}

model Reminder {
  id              String   @id @default(uuid())
  robot_id        String?
  robot           Robot?    @relation(fields: [robot_id], references: [id])
  title           String
  date            DateTime @db.Date
  time            String?
  type            String
  google_event_id String?
  created_at      DateTime @default(now())
}

model MusicGenreMapping {
  id             String   @id @default(uuid())
  robot_id       String?
  robot          Robot?    @relation(fields: [robot_id], references: [id])
  genre_name     String
  scent_name     String
  intensity      Int      @default(100)
  color_gradient String?
  updated_at     DateTime @updatedAt

  @@unique([robot_id, genre_name])
}

model GameSession {
  id            String   @id @default(uuid())
  robot_id      String?
  robot         Robot?   @relation(fields: [robot_id], references: [id])
  activity_type String
  game_name     String
  duration      Int
  score         Int?
  result        String?
  played_at     DateTime @default(now())
}

// Global Tables (Not linked to Robot)
model RevisionMaterial {
  id              String   @id @default(uuid())
  user_id         String
  file_url        String
  file_name       String
  content         String?
  uploaded_at     DateTime @default(now())
  expires_at      DateTime
  questions       RevisionQuestion[]
}

model RevisionQuestion {
  id           String           @id @default(uuid())
  material_id  String
  material     RevisionMaterial @relation(fields: [material_id], references: [id], onDelete: Cascade)
  question     String
  answer       String
  explanation  String?
}

model BreathingExercise {
  id            String   @id @default(uuid())
  title         String
  video_url     String
  duration_secs Int
}

model Game {
  id            String   @id @default(uuid())
  name          String
  description   String?
  thumbnail_url String?
}

model ModeUsageLog {
  id         String   @id @default(uuid())
  robot_id   String?
  robot      Robot?    @relation(fields: [robot_id], references: [id])
  mode       String
  start_time DateTime @default(now())
  end_time   DateTime?
}
